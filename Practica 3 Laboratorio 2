# Ser superusuario
sudo su

# Ver discos y particiones actuales
lsblk
fdisk -l

# Crear partición en /dev/sdb
fdisk /dev/sdb
# n → nueva partición
# p → primaria
# ENTER → inicio por defecto
# ENTER → final por defecto
# ENTER → confirmar
# w → guardar cambios

# Verificar nueva partición
lsblk
fdisk -l

# Formatear en EXT4
mkfs.ext4 /dev/sdb1

# Confirmar tipo de sistema de archivos
blkid /dev/sdb1

# Crear carpeta de montaje
mkdir ~/DiscoAdrian

# Montar disco en carpeta
mount /dev/sdb1 ~/DiscoAdrian

# Ver uso de espacio
df -h ~/DiscoAdrian

# Entrar y crear archivo
cd ~/DiscoAdrian
touch AdrianAlcantara.txt

# Volver al home
cd ~

# Desmontar disco
umount ~/DiscoAdrian

# Montar en /mnt
mount /dev/sdb1 /mnt

# Ver contenido y uso
ls /mnt
df -h /mnt

# Probar lectura del archivo
cat /mnt/AdrianAlcantara.txt
